AEAI_ENV=local
AEAI_SERVICE_NAME=autonomous-enterprise-ai-os
AEAI_API_PORT=8000
AEAI_ARTIFACT_ROOT=artifacts
AEAI_RUN_REPOSITORY_BACKEND=memory
AEAI_DATABASE_URL=postgresql+psycopg://aeai:aeai_password@postgres:5432/aeai_os

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=aeai_os
POSTGRES_USER=aeai
POSTGRES_PASSWORD=aeai_password

REDIS_HOST=redis
REDIS_PORT=6379

SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=aeai_minio
MINIO_SECRET_KEY=aeai_minio_password
MINIO_BUCKET=aeai-artifacts
