AEAI_ENV=local
AEAI_SERVICE_NAME=autonomous-enterprise-ai-os
AEAI_API_PORT=8000
AEAI_ARTIFACT_ROOT=artifacts
AEAI_ARTIFACT_STORAGE_BACKEND=local
AEAI_ARTIFACT_S3_BUCKET=aeai-artifacts
AEAI_ARTIFACT_S3_PREFIX=aeai-artifacts
AEAI_ARTIFACT_S3_ENDPOINT_URL=http://minio:9000
AEAI_ARTIFACT_S3_REGION=
AEAI_ARTIFACT_S3_ACCESS_KEY_ID=aeai_minio
AEAI_ARTIFACT_S3_SECRET_ACCESS_KEY=aeai_minio_password
AEAI_RUN_REPOSITORY_BACKEND=memory
AEAI_RUN_REPOSITORY_CREATE_SCHEMA=true
AEAI_DATABASE_URL=postgresql+psycopg://aeai:aeai_password@postgres:5432/aeai_os
AEAI_WORKFLOW_EXECUTION_MODE=sync
AEAI_WORKFLOW_QUEUE_BACKEND=repository
AEAI_WORKFLOW_QUEUE_TIMEOUT_SECONDS=300
AEAI_WORKFLOW_QUEUE_KEY_PREFIX=aeai:workflow
AEAI_REDIS_URL=redis://redis:6379/0
AEAI_AUTH_ENABLED=false
AEAI_AUTH_TOKEN_PROFILES=local-admin-token=local-admin|Local Admin|admin
AEAI_AUTH_LOCAL_USER_ID=local-dev
AEAI_AUTH_LOCAL_USER_NAME=Local Developer
AEAI_AUTH_LOCAL_ROLES=admin
AEAI_TRACING_ENABLED=true
AEAI_TRACE_EXPORTER=none
AEAI_OTEL_EXPORTER_OTLP_ENDPOINT=
AEAI_OTEL_EXPORTER_OTLP_HEADERS=
AEAI_OTEL_EXPORTER_OTLP_INSECURE=false
AEAI_MLFLOW_TRACKING_ENABLED=false
AEAI_MLFLOW_TRACKING_URI=
AEAI_MLFLOW_EXPERIMENT_NAME=Autonomous Enterprise AI OS
AEAI_MLFLOW_RUN_NAME_PREFIX=aeai-run
AEAI_MLFLOW_TAGS=
AEAI_LANGSMITH_TRACING_ENABLED=false
AEAI_LANGSMITH_API_KEY=
AEAI_LANGSMITH_ENDPOINT=
AEAI_LANGSMITH_PROJECT=Autonomous Enterprise AI OS
AEAI_LANGSMITH_RUN_NAME_PREFIX=aeai-run
AEAI_LANGSMITH_TAGS=

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=aeai_os
POSTGRES_USER=aeai
POSTGRES_PASSWORD=aeai_password

REDIS_HOST=redis
REDIS_PORT=6379

SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_CONNECT_TIMEOUT_SECONDS=15
SNOWFLAKE_QUERY_TIMEOUT_SECONDS=60
SNOWFLAKE_ROW_LIMIT=10000
SNOWFLAKE_APPLICATION=aeai-os

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=aeai_minio
MINIO_SECRET_KEY=aeai_minio_password
MINIO_BUCKET=aeai-artifacts
